{{ 'custom-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-header.js' | asset_url }}" defer></script>

<header class="custom-header {% if section.settings.transparent %}is-transparent{% endif %}">
  
  <!-- TOP ANNOUNCEMENT -->
  {% if section.settings.show_announcement %}
  <div class="header-top">
    <div class="container">
      <p>{{ section.settings.announcement_text }}</p>
    </div>
  </div>
  {% endif %}

  <!-- MAIN HEADER -->
  <div class="header-main container">

    <!-- LEFT: LOGO -->
    <div class="header-left">
      <a href="{{ routes.root_url }}" class="header-logo">
        {% if settings.logo != blank %}
          <img src="{{ settings.logo | image_url }}" alt="{{ shop.name }}">
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- CENTER: NAV -->
    <nav class="header-nav">
      <ul>
        {% for link in section.settings.menu.links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- RIGHT: ACTIONS -->
    <div class="header-right">

      <!-- SEARCH -->
      <form action="{{ routes.search_url }}" method="get" class="header-search">
        <input type="text" name="q" placeholder="Search for products">
        <button type="submit">
          🔍
        </button>
      </form>

      <!-- ACCOUNT -->
      <a href="{{ routes.account_url }}" class="header-icon">
        👤
      </a>

      <!-- CART -->
      <a href="{{ routes.cart_url }}" class="header-icon cart-icon">
        🛒
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>

    </div>

  </div>
</header>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "transparent",
      "label": "Enable Transparent Header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Discover Rare, Designer & Vintage Finds...Catch Them Before They’re Gone"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}